[
    {kernel, [
        {logger_level, notice},
        %% Fix distribution port to 9103 (predictable for firewall rules)
        {inet_dist_listen_min, 9103},
        {inet_dist_listen_max, 9103},
        %% Bind distribution to localhost only (hardening)
        %% Remove this line to allow cluster connections from other hosts
        {inet_dist_use_interface, {127,0,0,1}}
    ]},
    {erlkoenig_elf, [
        {socket_path, "/run/erlkoenig_elf/ctl.sock"}
    ]}
].
